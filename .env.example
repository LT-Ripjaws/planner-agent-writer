APP_NAME="Planner Agent Writer API"
ENVIRONMENT="development"
DATABASE_URL="sqlite:///./backend/data/app.db"
CHECKPOINT_DATABASE_PATH="./backend/data/checkpoints.db"
RUN_FALLBACK_TIMEOUT_SECONDS="3600"
WRITER_TIMEOUT_SECONDS="900"
WRITER_MAX_CONCURRENCY="2"
RATE_LIMIT_RUNS_PER_MIN="6"
HITL_PLAN_APPROVAL_ENABLED="false"
HITL_APPROVAL_TIMEOUT_HOURS="24"
QUALITY_EVAL_ENABLED="true"
QUALITY_THRESHOLD="7.0"
QUALITY_MAX_ITERATIONS="2"
QUALITY_MAX_SECTIONS_PER_ITER="1"
QUALITY_NODE_TIMEOUT_SECONDS="900"
QUALITY_MIN_IMPROVEMENT_SECONDS="90"
QUALITY_LLM_TIMEOUT_SECONDS="280"
EVALUATOR_MAX_SECTIONS_PER_CALL="4"
CORS_ORIGINS="http://localhost:3000"
LLM_API_KEY=""
LLM_BASE_URL="https://api.kilo.ai/api/gateway"
LLM_MODEL="nvidia/nemotron-3-super-120b-a12b:free"
LLM_TIMEOUT_SECONDS="180"
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Optional 3rd provider: OpenAI (or any OpenAI-compatible endpoint). Leave the
# key empty to keep it off. To route a lane here, set e.g.
# WRITER_PROVIDER="openai" + WRITER_MODEL="gpt-4o-mini" (and a paid OPENAI_API_KEY). 
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# --- Multi-provider per-role routing ---
# Writers: A fast prose model would suit here better but your choice.
WRITER_PROVIDER="kilo"
WRITER_MODEL="stepfun/step-3.7-flash:free"

# Router + planner + evaluator + citation repair: strong structured model would do a legit job here.
# (i used openrouter). Degrades to LLM_MODEL on Kilo when
# OPENROUTER_API_KEY is unset.
REASONING_PROVIDER="openrouter" # You're free to set this to kilo or openai even
REASONING_MODEL="moonshotai/kimi-k2.6:free"
# Cross-provider fallback when the reasoning lane errors (OpenRouter 503/429).
LLM_FALLBACK_ENABLED="true"
FALLBACK_PROVIDER="kilo"
FALLBACK_MODEL="nvidia/nemotron-3-super-120b-a12b:free"

TAVILY_API_KEY=""
